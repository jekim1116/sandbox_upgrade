FROM node:18-bullseye-slim

RUN apt-get update && apt-get install -y python3 python3-pip bubblewrap && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 기본 패키지 (모든 Python 플러그인 공통)
RUN pip3 install numpy pandas requests beautifulsoup4

# {{PLUGIN_PACKAGES}}

RUN npm install bullmq@4

COPY worker-server/ .

CMD ["node", "index.js"]
